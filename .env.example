# DA-INVENT — Variabili d'ambiente
# Copia in .env.local e adatta i valori.
# L'installer genera automaticamente ENCRYPTION_KEY e AUTH_SECRET.

# Obbligatorie (generate al setup o dall'installer)
ENCRYPTION_KEY=
AUTH_SECRET=

# Opzionali
PORT=3001
NODE_ENV=production

# Auth.js: accesso via IP o hostname vari (LXC, LAN). Default = host attendibile.
# Solo in casi avanzati: AUTH_TRUST_HOST=false e imposta AUTH_URL esplicito.
# AUTH_URL=https://invent.example.com
# AUTH_TRUST_HOST=true

# TLS/HTTPS (opzionale - per accesso HTTPS diretto)
# TLS_CERT=data/certs/cert.pem
# TLS_KEY=data/certs/key.pem
# TLS_REDIRECT=true
# HTTP_PORT=80

# WinRM (opzionale, per comandi su host Windows)
# WINRM_PYTHON=/path/to/python3

# Device fingerprinting (discovery nmap/snmp)
# DA_INVENT_FINGERPRINT=false
# DA_INVENT_FINGERPRINT_PROBES=false
# DA_INVENT_FINGERPRINT_TTL=false

# Fallback SNMP: usa il binario snmpwalk se net-snmp (Node) non ottiene sysDescr
# DA_INVENT_SNMPWALK_CLI=false

# Discovery: DNS (evita scan bloccati su PTR lenti)
# DA_INVENT_DNS_TIMEOUT_MS=2500
# DA_INVENT_DNS_CONCURRENCY=16
# Log resolver + ogni query (solo debug; senza questo non logga nulla su DNS)
# DA_INVENT_DNS_VERBOSE=false
# Cache in-memory reverse/forward (ms)
# DA_INVENT_DNS_CACHE_TTL_MS=1800000
# DA_INVENT_DNS_NEGATIVE_CACHE_TTL_MS=300000
# Discovery: rifare sempre PTR anche se dns_reverse è già in DB
# DA_INVENT_DNS_ALWAYS_REFRESH=false
# Job dns_resolve: interrogare di nuovo la rete anche se dns_reverse è già salvato
# DA_INVENT_DNS_CRON_REFRESH_STORED=false

# Nmap: timeout per singolo host su scan TCP/UDP completo (default 75s; TLS es. Proxmox :8006)
# DA_INVENT_NMAP_HOST_TIMEOUT_S=75
# Quanti host sottoporre a nmap port scan in parallelo (default 2; valori alti possono far perdere porte)
# DA_INVENT_NMAP_PORT_SCAN_CONCURRENCY=2
# Scoperta rete — fase Nmap quick dopo ICMP (separata dal timeout sopra)
# DA_INVENT_NMAP_DISCOVERY_QUICK_TIMEOUT_S=10
# DA_INVENT_NMAP_DISCOVERY_CONCURRENCY=6
# Limite duro (ms) sul processo nmap per host in quick (uccide se superato)
# DA_INVENT_NMAP_DISCOVERY_EXEC_MS=22000

# Fingerprint: oltre N host online non eseguire HTTP/SSH/SMB (default 8)
# DA_INVENT_FINGERPRINT_PROBES_MAX_HOSTS=8
# DA_INVENT_FINGERPRINT_HTTP_TIMEOUT_MS=2200
# DA_INVENT_FINGERPRINT_SSH_TIMEOUT_MS=2200
# DA_INVENT_FINGERPRINT_SMB_TIMEOUT_MS=4500
