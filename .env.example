# DA-INVENT — Variabili d'ambiente
# Copia in .env.local e adatta i valori.
# L'installer genera automaticamente ENCRYPTION_KEY e AUTH_SECRET.

# Obbligatorie (generate al setup o dall'installer)
ENCRYPTION_KEY=
AUTH_SECRET=

# Opzionali
PORT=3001
NODE_ENV=production

# TLS/HTTPS (opzionale - per accesso HTTPS diretto)
# TLS_CERT=data/certs/cert.pem
# TLS_KEY=data/certs/key.pem
# TLS_REDIRECT=true
# HTTP_PORT=80

# WinRM (opzionale, per comandi su host Windows)
# WINRM_PYTHON=/path/to/python3
