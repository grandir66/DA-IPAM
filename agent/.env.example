# Esempio configurazione DA-INVENT Agent v0.2.0+
#
# Copia in `.env` (NON committato) o esporta direttamente nello shell.
# In produzione la fonte canonica è /etc/da-invent-agent/config.yml,
# che ha la stessa struttura ma in YAML.

# ─── Identità del tenant ────────────────────────────────────────────────
DA_INVENT_AGENT_TENANT_CODE=CLIENTE-001
DA_INVENT_AGENT_HUB_URL=https://da-invent.domarc.it

# ─── Binding ────────────────────────────────────────────────────────────
DA_INVENT_AGENT_PORT=8443
DA_INVENT_AGENT_HOST=0.0.0.0

# ─── Dev / log ──────────────────────────────────────────────────────────
# In dev_mode accettiamo richieste da 127.0.0.1 e saltiamo il check tailscale0.
# In produzione DEVE essere false.
DA_INVENT_AGENT_DEV_MODE=true
DA_INVENT_AGENT_LOG_LEVEL=INFO

# ─── Tokens (BREAKING CHANGE v0.2.0) ────────────────────────────────────
# Lista JSON di bearer token. Ogni entry ha:
#   - label:      nome identificativo per audit log (mai usare il plaintext)
#   - token_hash: bcrypt hash del plaintext (cost ≥ 10 in produzione)
#   - scopes:     subset di {"exec:network","exec:device","admin:update"} oppure ["*"]
#
# Genera l'hash con:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'PLAINTEXT', bcrypt.gensalt()).decode())"
DA_INVENT_AGENT_TOKENS=[{"label":"hub-prod","token_hash":"$2b$10$...","scopes":["exec:network","exec:device"]}]
