+	var sig = Buffer.from('NTLMSSP\0', 'ascii');
+	for (var i = 0; i <= buf.length - sig.length; i++) {
+		if (buf.slice(i, i + sig.length).equals(sig) && (buf.readUInt16LE(i + 8) === 2 || buf.readUInt32LE(i + 8) === 2)) {
+			var o = i;
+			var targetNameMaxLen = buf.readUInt16LE(o + 14);
+			var targetNameOffset = buf.readUInt32LE(o + 16);
+			var end = o + Math.max(56, targetNameOffset + targetNameMaxLen);
+			if (buf.length >= o + 44 && (buf.readUInt32LE(o + 20) & 0x00800000)) {
